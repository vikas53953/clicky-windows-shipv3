{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clicky Windows",
  "version": "0.1.0",
  "identifier": "com.pylabmit.clicky.windows",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Clicky Windows",
        "width": 1180,
        "height": 760,
        "resizable": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
